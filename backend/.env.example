# ── Environment Variables ────────────────────────────────────────
# Copy this file to .env and fill in your values.

# Brevo (Sendinblue) — get from: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your_brevo_api_key_here
BREVO_SENDER_EMAIL=noreply@thingual.com
BREVO_SENDER_NAME=Thingual

# Google OAuth — get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# JWT — any long random string (e.g. openssl rand -hex 32)
JWT_SECRET=change_this_to_a_random_secret_string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080   # 7 days

# Gemini / Google Generative AI — get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
