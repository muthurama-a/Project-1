        "prompt": "Someone says: 'Hi! How are you doing today?'",
        "example_response": "I'm doing great, thank you! How about you? Nice to meet you. Goodbye, see you later!",
        "key_phrases": ["I'm fine", "I'm great", "Not bad", "Thank you"],
        "min_words": 10
      }
    },
