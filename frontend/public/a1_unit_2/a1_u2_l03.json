  "tasks": [
    {
      "task_id": "t0203_01", "order": 1, "type": "learn_card", "category": "vocabulary",
      "title": "Telling the time — the basics",
      "content": {
        "explanation": "In English we read time in a specific way. Learn these patterns.",
        "time_patterns": [
          { "pattern": "o'clock", "use": "Exactly on the hour", "examples": ["7 o'clock", "12 o'clock", "3 o'clock"] },
          { "pattern": "half past ___", "use": "30 minutes past the hour", "examples": ["half past seven = 7:30", "half past three = 3:30"] },
          { "pattern": "quarter past ___", "use": "15 minutes past the hour", "examples": ["quarter past two = 2:15", "quarter past nine = 9:15"] },
          { "pattern": "quarter to ___", "use": "15 minutes before the NEXT hour", "examples": ["quarter to eight = 7:45", "quarter to one = 12:45"] },
          { "pattern": "___ minutes past ___", "use": "1–29 minutes past the hour", "examples": ["ten past six = 6:10", "twenty past four = 4:20"] },
          { "pattern": "___ minutes to ___", "use": "1–29 minutes before the next hour", "examples": ["ten to nine = 8:50", "five to twelve = 11:55"] }
        ]
      }
    },
    {
      "task_id": "t0203_02", "order": 2, "type": "learn_card", "category": "vocabulary",
      "title": "AM and PM / Morning and evening",
      "content": {
        "explanation": "We can say AM/PM or use words like morning, afternoon, and evening.",
        "items": [
          { "phrase": "in the morning", "note": "12am – 12pm (midnight to noon)" },
          { "phrase": "in the afternoon", "note": "12pm – 6pm" },
          { "phrase": "in the evening", "note": "6pm – bedtime" },
          { "phrase": "at night", "note": "Late — when it's dark and quiet" },
          { "phrase": "at midnight", "note": "Exactly 12am" },
          { "phrase": "at noon / midday", "note": "Exactly 12pm" }
        ],
        "examples": [
          "My class is at 9 o'clock in the morning.",
          "I have lunch at half past twelve.",
          "The film starts at quarter past seven in the evening."
        ]
      }
    },
    {
      "task_id": "t0203_03", "order": 3, "type": "learn_card", "category": "vocabulary",
      "title": "Asking and saying the time",
      "content": {
        "explanation": "Use these phrases to ask and answer time questions.",
        "items": [
          { "phrase": "What time is it?", "note": "Standard question — very common" },
          { "phrase": "What's the time?", "note": "Casual version — same meaning" },
          { "phrase": "Do you have the time?", "note": "Polite way to ask a stranger" },
          { "phrase": "It's ___ o'clock.", "note": "Answer for exact hour" },
          { "phrase": "It's half past ___.", "note": "Answer for :30" },
          { "phrase": "It's about ___.", "note": "Approximate — 'It's about three o'clock'" }
        ]
      }
    },
    {
      "task_id": "t0203_04", "order": 4, "type": "listen_repeat", "category": "pronunciation",
      "title": "Listen and repeat — time phrases",
      "content": {
        "instruction": "Repeat each time expression. Listen carefully to the rhythm.",
        "phrases": [
          { "text": "It's seven o'clock.", "audio_key": "seven_oclock" },
          { "text": "It's half past three.", "audio_key": "half_past_three" },
          { "text": "It's quarter past nine.", "audio_key": "quarter_past_nine" },
          { "text": "It's quarter to eight.", "audio_key": "quarter_to_eight" },
          { "text": "What time is it, please?", "audio_key": "what_time_please" }
        ]
      }
    },
    {
      "task_id": "t0203_05", "order": 5, "type": "mcq", "category": "knowledge_check",
      "title": "What time is it?",
      "content": {
        "question": "The clock shows 3:30. How do you say this in English?",
        "options": ["Three thirty o'clock", "Half past three", "Quarter to three", "Quarter past three"],
        "correct_index": 1,
        "explanation": "3:30 = 30 minutes past 3 = half past three."
      }
    },
    {
      "task_id": "t0203_06", "order": 6, "type": "mcq", "category": "knowledge_check",
      "title": "What time is it?",
      "content": {
        "question": "The clock shows 7:45. How do you say this?",
        "options": ["Quarter past seven", "Half past seven", "Quarter to eight", "Seven forty-five o'clock"],
        "correct_index": 2,
        "explanation": "7:45 = 15 minutes before 8 = quarter to eight."
      }
    },
    {
      "task_id": "t0203_07", "order": 7, "type": "mcq", "category": "knowledge_check",
      "title": "Which time is correct?",
      "content": {
        "question": "'My train leaves at ten past six.' What time does the train leave?",
        "options": ["6:00", "6:10", "6:30", "5:50"],
        "correct_index": 1,
        "explanation": "Ten past six = 10 minutes after 6 = 6:10."
      }
    },
    {
      "task_id": "t0203_08", "order": 8, "type": "fill_blank", "category": "knowledge_check",
      "title": "Fill in the time expression",
